# frontend/.env.example
#
# Example environment variables for the Next.js app.
#
# Notes:
# - Do not commit real secrets.

# Backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000/api/v1
# Optional: internal URL for server-side rendering (used when the Next.js
# server cannot reach the public URL, e.g. behind a reverse proxy / Docker).
# BACKEND_INTERNAL_URL=http://backend:8000/api/v1

# NextAuth/Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Authentik OIDC
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Cloudflare Turnstile (anonymous battle creation verification).
# Must be paired with TURNSTILE_SECRET_KEY in the backend — setting only one
# side breaks anonymous battle creation. Leave both empty to disable Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# OIDC origins for CSP connect-src (comma-separated).
# Required when the Authentik issuer differs from the frontend origin.
# NEXT_PUBLIC_OIDC_ORIGINS=https://auth.example.com

# Admin authorization
# Admin gating is handled entirely by the backend. The backend checks Authentik
# group membership using its own OIDC_ADMIN_GROUP_CLAIM / OIDC_ADMIN_GROUP_NAME
# settings and exposes the result as `is_admin` on the /me endpoint. The
# frontend reads that boolean to show or hide admin UI. No frontend env vars
# are needed for admin access control.
