# frontend/.env.example
#
# Example environment variables for the Next.js app.
#
# Notes:
# - Do not commit real secrets.

# Backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000/api/v1
# Optional: internal URL for server-side rendering (used when the Next.js
# server cannot reach the public URL, e.g. behind a reverse proxy / Docker).
# BACKEND_INTERNAL_URL=http://backend:8000/api/v1

# NextAuth/Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Authentik OIDC
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Cloudflare Turnstile (anonymous vote verification)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Admin authorization (frontend gating)
# Matches backend defaults: OIDC_ADMIN_GROUP_CLAIM=groups, OIDC_ADMIN_GROUP_NAME=arena_admin.
NEXT_PUBLIC_ADMIN_GROUP_CLAIM=groups
NEXT_PUBLIC_ADMIN_GROUP_NAME=arena_admin
