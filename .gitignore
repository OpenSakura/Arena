# .gitignore
#
# Git ignore rules for this monorepo.
#
# Notes:
# - Keep secrets out of git (.env, local keys, etc.).

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/

# Node / Next
node_modules/
.next/
out/
dist/
playwright-report/
test-results/
*.tsbuildinfo

# Logs
*.log

# Env files
.env
.env.*
!.env.example

# Local e2e test secrets
backend/tests/e2e/test.env

# OS
.DS_Store

# Tool / IDE data
.sisyphus/
.playwright-mcp/
.omo/

# Third-party cloned repos
3rdparty/

# Scratch / debug files
/notes.md
/admin-network.txt
/admin-snapshot.md
/t8-*.txt
/task8-*.txt
/*.png
frontend/debug.js
frontend/output.txt
frontend/run_test.mjs
