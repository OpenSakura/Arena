# backend/.env.example
#
# Example environment variables for the backend.
#
# Notes:
# - Do not commit real secrets.

# Core
APP_ENV=dev
APP_NAME=OpenSakura Arena API
API_V1_PREFIX=/api/v1

# Worker count: battle execution uses in-process singletons that are NOT safe
# across multiple OS processes.  Always set to 1.  Starting with > 1 will cause
# the server to refuse to start.
WEB_CONCURRENCY=1

# Logging / observability
# Leave LOG_LEVEL empty to auto-select by APP_ENV.
LOG_LEVEL=
LOG_JSON=false
# Enable request access logs (method/path/status/latency).
ACCESS_LOG_ENABLED=false

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/arena

# CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000

# OIDC (Authentik)
# Example issuer: https://auth.example.com/application/o/arena/
OIDC_ISSUER=
# If your access tokens include an audience claim you want to enforce.
OIDC_AUDIENCE=
OIDC_ADMIN_GROUP_CLAIM=groups
OIDC_ADMIN_GROUP_NAME=arena_admin
OIDC_JWKS_CACHE_TTL_SECONDS=300
OIDC_HTTP_TIMEOUT_SECONDS=5

# Cloudflare Turnstile (optional extra anti-abuse layer).
# Battle creation requires authentication regardless of Turnstile config.
# Setting TURNSTILE_SECRET_KEY enables server-side token verification.
# Leave empty to disable Turnstile.
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Rate limits (set <= 0 to disable each limiter).
ANON_RATE_LIMIT_BUCKET_SECONDS=10
AUTH_BATTLE_CREATE_RATE_LIMIT=60
AUTH_BATTLE_CREATE_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_BATTLE_STREAM_RATE_LIMIT=90
AUTH_BATTLE_STREAM_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_VOTE_SUBMIT_RATE_LIMIT=90
AUTH_VOTE_SUBMIT_RATE_LIMIT_WINDOW_SECONDS=60

# Redis backend for rate limiting and shared caching.
# Leave empty to disable Redis-backed throttling and the shared
# confidence-interval result cache.
# Example: redis://localhost:6379/0
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_KEY_PREFIX=arena
RATE_LIMIT_REDIS_TIMEOUT_SECONDS=0.25

# Trust X-Forwarded-For header for client IP extraction behind a reverse
# proxy.  MUST only be enabled behind a trusted proxy (e.g. Nginx, Caddy).
TRUST_X_FORWARDED_FOR=false

# Secret encryption (used to encrypt provider tokens stored in Postgres)
# Generate a 32-byte key and base64-url encode it.
ARENA_MASTER_KEY=
# Optional: previous master key for zero-downtime key rotation.
# Set this to the old key value while re-encrypting existing secrets, then
# clear it once all secrets have been migrated to the new key.
ARENA_MASTER_KEY_OLD=

# FastChat-inspired battle sampling config (all optional, JSON values).
# Match keys against model ``model_name``.
# Example:
# BATTLE_SAMPLING_WEIGHTS={"gpt-4o-mini":1.0,"qwen2.5-72b":0.6}
# BATTLE_TARGETS={"gpt-4o-mini":["qwen2.5-72b","deepseek-v3"]}
# BATTLE_STRICT_TARGETS={"gpt-4o-mini":["qwen*","deepseek*"]}
# BATTLE_OUTAGE_MODELS=["model-temporarily-down"]
# BATTLE_SAMPLING_BOOST_MODELS=["new-model-preview"]
BATTLE_SAMPLING_WEIGHTS={}
BATTLE_TARGETS={}
BATTLE_STRICT_TARGETS={}
BATTLE_OUTAGE_MODELS=[]
BATTLE_SAMPLING_BOOST_MODELS=[]
# Max wall-clock seconds an active battle execution task may run before being force-failed.
BATTLE_RUNNING_WAIT_TIMEOUT_SECONDS=600

# Periodic leaderboard refresh job.
LEADERBOARD_REFRESH_ENABLED=true
LEADERBOARD_REFRESH_INTERVAL_SECONDS=300
# 0 disables per-judge daily vote cap.
LEADERBOARD_REFRESH_DAILY_VOTE_CAP=0
LEADERBOARD_REFRESH_ELO_K=32

# Confidence-enabled leaderboard requests (CPU-expensive, cached + throttled).
LEADERBOARD_CONFIDENCE_CACHE_TTL_SECONDS=15
LEADERBOARD_CONFIDENCE_RATE_LIMIT=6
LEADERBOARD_CONFIDENCE_RATE_LIMIT_WINDOW_SECONDS=60

# Elo confidence interval settings (computed on demand).
LEADERBOARD_ELO_BOOTSTRAP_ROUNDS=200
LEADERBOARD_ELO_BOOTSTRAP_SEED=0
LEADERBOARD_ELO_CONFIDENCE_LEVEL=0.95

# Shuffle-and-average Elo: run multiple shuffled passes to reduce
# order-dependent rating artifacts.  0 or 1 uses a single pass.
LEADERBOARD_ELO_SHUFFLE_ROUNDS=5
LEADERBOARD_ELO_SHUFFLE_SEED=0

# Bradley-Terry leaderboard (computed on demand via /leaderboard?method=bt)
LEADERBOARD_BT_MAX_ITERATIONS=200
LEADERBOARD_BT_TOLERANCE=1e-6
LEADERBOARD_BT_BOOTSTRAP_ROUNDS=200
LEADERBOARD_BT_BOOTSTRAP_SEED=0
LEADERBOARD_BT_PRIOR=1e-6
LEADERBOARD_BT_CONFIDENCE_LEVEL=0.95
